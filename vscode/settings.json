{
    "workbench.colorTheme": "Catppuccin Macchiato",
    "workbench.iconTheme": "catppuccin-macchiato",
    "workbench.tree.expandMode": "doubleClick",
    "workbench.editor.limit.enabled": true,
    "workbench.editor.limit.perEditorGroup": true,
    "workbench.editor.limit.value": 10,

    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 500,
    "files.trimTrailingWhitespace": true,
    "files.trimFinalNewlines": true,
    "[markdown]": {
        "files.trimTrailingWhitespace": false
    },

    "editor.fontSize": 16,
    "editor.smoothScrolling": true,
    "editor.stickyScroll.enabled": true,
    "editor.mouseWheelScrollSensitivity": 1.5,
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.cursorBlinking": "smooth",
    "editor.largeFileOptimizations": true,
    "editor.hover.delay": 600,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.foldingImportsByDefault": true,
    "editor.suggest.insertMode": "insert",
    "editor.rulers": [/* 80, */ 120],

    "search.showLineNumbers": true,
    "search.smartCase": true,

    "terminal.integrated.scrollback": 10000,
    "terminal.integrated.persistentSessionScrollback": 5000,

    "window.commandCenter": false,

    "explorer.autoReveal": false,
    "diffEditor.ignoreTrimWhitespace": false,
    // "workbench.iconTheme": "vscode-icons",
    "git.autofetch": true,
    "git.confirmSync": false,
    "extensions.autoUpdate": false,
    "terminal.integrated.rightClickBehavior": "default",
    "telemetry.enableTelemetry": false,

    "catppuccin.accentColor": "lavender",
    "catppuccin.italicKeywords": false,
    "catppuccin.italicComments": false,
    "catppuccin.boldKeywords": true,

    "editor.semanticHighlighting.enabled": true,

    "workbench.colorCustomizations": {
        "[Catppuccin Macchiato]": {
            "sideBar.background": "#262A32",
            "panel.border": "#434856",
            "panel.background": "#262A32",
            "sideBarSectionHeader.background": "#262A32",
            "statusBar.background": "#343844",
            "statusBar.noFolderBackground": "#343844",
            "statusBar.border": "#343844",
            "titleBar.activeBackground": "#262A32",
            "titleBar.inactiveBackground": "#292C35",
            "breadcrumb.background": "#262A32",
            "minimap.background": "#262A32",
            "editorOverviewRuler.background": "#262A32",
            "editorGutter.background": "#262A32",
            "editorGutter.modifiedBackground": "#ebcb8b",
            "tab.activeBorderTop": "#c6a0f6",
            "tab.hoverBorder": "#c6a0f6",
            "tab.activeBackground": "#262A32",
            "tab.inactiveBackground": "#262A32",
            "tab.inactiveForeground": "#cad3f5cb",
            "editorGroupHeader.tabsBackground": "#262A32",
            "editorGroupHeader.noTabsBackground": "#262A32",
            "activityBar.foreground": "#d8dee9",
            "activityBar.activeBorder": "#d8dee973",
            "activityBarBadge.background": "#d8dee9bb",
            "editorWidget.background": "#24262E",
            "widget.shadow": "#d8dee927",
            "notifications.background": "#24262E",
            "list.activeSelectionBackground": "#434959",
            "list.inactiveSelectionBackground": "#373c49",
            "list.activeSelectionForeground": "#e8e8e8",
            "list.errorForeground": "#bf616a",
            "gitDecoration.untrackedResourceForeground": "#a2c981",
            "gitDecoration.modifiedResourceForeground": "#ebcb8b",
            "statusBarItem.remoteForeground": "#e8e8e8",
            "statusBarItem.remoteBackground": "#39425e",
            "menu.background": "#262A32",
            "input.background": "#262A32",
            "quickInput.background": "#262A32",
            "quickInputList.focusBackground": "#4a5164",
            "quickInputList.focusForeground": "#cfd2db",
            "terminal.background": "#262A32",
            "commandCenter.background": "#262A32",
            "activityBar.background": "#282a33",
            "editor.background": "#262A32",
            "editor.selectionBackground": "#484e64",
            "editor.wordHighlightBackground": "#5e6683a8",
            "editorBracketMatch.background": "#4a4f5f",
            "editorBracketMatch.border": "#7a829c",
            "editorBracketHighlight.foreground1": "#f5a97f",
            "editorBracketHighlight.foreground2": "#eed49f",
            "editorBracketHighlight.foreground3": "#a6da95",
            "editorBracketHighlight.foreground4": "#86b5eb",
            "editorBracketHighlight.foreground5": "#68b6ff",
            "editorBracketHighlight.foreground6": "#9d96ff",
            "editorRuler.foreground": "#34414e"
        },
        "statusBar.background": "#519aba",
        "statusBar.noFolderBackground": "#519aba",
        "statusBar.debuggingBackground": "#519aba"
    },

    "editor.tokenColorCustomizations": {
        "[Catppuccin Macchiato]": {
        "textMateRules": [
            {
                "scope": ["punctuation", "punctuation.separator"],
                "settings": {
                    "foreground": "#8fbcbb"
                }
            },
            {
                "scope": ["keyword.operator.assignment.c,keyword.operator.comparison.c,keyword.operator.c,keyword.operator.increment.c,keyword.operator.decrement.c,keyword.operator.bitwise.shift.c,keyword.operator.assignment.cpp,keyword.operator.comparison.cpp,keyword.operator.cpp,keyword.operator.increment.cpp,keyword.operator.decrement.cpp,keyword.operator.bitwise.shift.cpp"],
                "settings": {
                    "foreground": "#b48ead"
                }
            },
            {
                "name": "Variables",
                "scope": [
                    "variable",
                    "variable.c",
                    "variable.language",
                    "entity.other",
                    "token.variable.parameter.java",
                    "variable.other.class.js",
                    "variable.other.class.js",
                    "variable.interpolation",
                    "entity.name.variable.local.cs",
                    "variable.parameter.function.js",
                    "variable.parameter.function.coffee",
                    "meta.variable",
                    "meta.definition.variable.name.groovy",
                    "text.variable",
                    "entity.name.variable.parameter.cs",
                    "entity.name.variable.field.cs",
                    "variable.parameter.function.latex",
                    "variable.other.object",
                    "variable.other.readwrite.c",
                    "variable.other.constant.property",
                    "support.variable.magic.python",
                    "variable.parameter.function.language.special.cls.python",
                    "variable.language.rust",
                    "variable.parameter.function",
                    "meta.definition.variable.name.java",
                    "variable.other.readwrite,meta.object-literal.key,support.variable.property,support.variable.object.process,support.variable.object.node",
                    "variable.parameter.function.language.python",
                ],
                "settings": {
                    "foreground": "#8fBCBB"
                }
            },
            {
                "name": "function parameters",
                "scope": [
                    "function.parameter",
                    "function.parameter.ruby",
                    "function.parameter.cs",
                    "variable.parameter.function.js",
                    "meta.arguments.coffee",
                    "variable.parameter.function.coffee",
                    "variable.parameter.function"

                ],
                "settings": {
                    "foreground": "#abb2bf"
                }
            },
    ],
        "comments": "#6e86a1",
        // "comments": "#9399b2",
    }
    },

    "vim.leader": "<space>",
    "vim.useSystemClipboard": true,
    "vim.useCtrlKeys": true,
    "vim.smartRelativeLine": true,
    "vim.incsearch": true,
    "vim.hlsearch": true,
    "vim.searchHighlightColor": "rgba(180, 142, 173, 0.5)", // Search highlight colour

    "vim.highlightedyank.enable": true,
    "vim.statusBarColorControl": true,                   // Enable status bar colour changes
    "vim.statusBarColors.normal": "#519aba",             // Blue for normal mode
    "vim.statusBarColors.insert": "#98c379",             // Green for insert mode
    "vim.statusBarColors.visual": "#c678dd",             // Purple for visual mode
    "vim.statusBarColors.visualline": "#c678dd",         // Purple for visual line mode
    "vim.statusBarColors.visualblock": "#c678dd",        // Purple for visual block mode
    "vim.statusBarColors.replace": "#e06c75",            // Red for replace mode

    "vim.handleKeys": {
        "<C-p>": false, // quick open,
        "<C-d>": false, // duplicate line
        "<C-k>": true, // scroll down
        "<C-l>": true, // scroll up
        "<C-f>": false, // vscode search
        "<C-b>": false, // vscode sidebar toggle
        "<C-w>": false, // close tab
        "<C-s>": false, // save file
        "<C-a>": false, // select all
        "<C-c>": false, // copy
        "<C-v>": false, // paste
        "<C-z>": false, // undo
        "<C-r>": false, // find and replace (but potentially could be changed to redo)
    },

    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": ["j"],
            "after": ["h"]
        },
        {
            "before": ["k"],
            "after": ["j"]
        },
        {
            "before": ["l"],
            "after": ["k"]
        },
        {
            "before": [";"],
            "after": ["l"]
        },
        {
            "before": ["<leader>", "<leader>"],
            "commands": ["whichkey.show"]
        },
        {
            "before": ["<Esc>"],
            "commands": [":nohl"]
        },
        {
            "before": ["K"],
            "commands": ["editor.action.showHover"]
        },
        {
            "before": ["<leader>", "f"],
            "commands": ["workbench.action.quickOpen"]
        },
        {
            "before": ["<leader>", "e"],
            "commands": ["workbench.files.action.showActiveFileInExplorer"]
        },
        {
            "before": ["<leader>", "t"],
            "commands": ["workbench.action.terminal.toggleTerminal"]
        },
        {
            "before": ["g", "d"],
            "commands": ["editor.action.revealDefinition"]
        },
        {
            "before": ["g", "D"],
            "commands": ["editor.action.revealDeclaration"]
        },
        {
            "before": ["g", "r"],
            "commands": ["editor.action.goToReferences"]
        },
        {
            "before": ["g", "i"],
            "commands": ["editor.action.goToImplementation"]
        },
        {
            "before": ["g", "y"],
            "commands": ["editor.action.goToTypeDefinition"]
        },
        {
            "before": ["<leader>", "h"],
            "commands": ["editor.action.triggerParameterHints"]
        },

        // git
        {
            "before": ["<leader>", "g", "b"],
            "commands": ["git.blame.toggleEditorDecoration"]
        },
        {
            "before": ["<leader>", "g", "d"],
            "commands": ["git.openChange"]
        },
        {
            "before": ["<leader>", "l"],
            "commands": ["git.commit.ViewChangeLog"]
        },
    ],

    "vim.visualModeKeyBindingsNonRecursive": [
        {
            "before": ["<leader>"],
            "commands": ["whichkey.show"]
        },
        {
            "before": ["<leader>", "/"],
            "commands": ["workbench.action.findInFiles"]
        },
    ],

    "git.blame.editorDecoration.enabled": false
}

